# Backend URL for the Learn & Earn quiz/sign API.
# Default works against `npm run dev` in ../hamzacoin-backend.
VITE_BACKEND_URL=http://localhost:3001

# Deployed HamzaFaucet contract address on Sepolia.
# Set this AFTER running `npx hardhat run scripts/deploy-faucet.js --network sepolia`
# in ../../crypto_class. If left empty, the Learn & Earn claim button is
# disabled with a friendly "Faucet not configured" message — the rest of the
# dApp still works.
VITE_FAUCET_ADDRESS=

# Dedicated Sepolia RPC URL (HIGHLY RECOMMENDED).
# Without this, the dApp uses three public RPCs (publicnode, drpc, 1rpc)
# that throttle hard with HTTP 429 when several hooks poll in parallel.
# Symptoms: balance stays as "..." forever, console spammed with 429s.
#
# Get a free key:
#   - https://dashboard.alchemy.com → Create App → Ethereum → Sepolia →
#     copy HTTPS URL (looks like https://eth-sepolia.g.alchemy.com/v2/yourkey)
#   - https://infura.io is also free
#
# Leave blank to use the public RPCs (with a smaller default history window).
VITE_SEPOLIA_RPC_URL=
